prefix=@CMAKE_INSTALL_PREFIX@
exec_prefix=${prefix}
symbol_prefix=@ZLIB_SYMBOL_PREFIX@
bindir=@PC_BIN_INSTALL_DIR@
libdir=@PC_LIB_INSTALL_DIR@
sharedlibdir=${libdir}
includedir=@PC_INC_INSTALL_DIR@

Name: @ZLIB_NAMESUFFIX@
Description: neozip compression library
Version: @ZLIB_FULL_VERSION@

Requires:
Libs: -L${libdir} -L${sharedlibdir} -l@ZLIB_UNIXLIBNAME@
Cflags: -I${includedir} @PKG_CONFIG_CFLAGS@
