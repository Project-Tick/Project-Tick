prefix=@prefix@
exec_prefix=@exec_prefix@
symbol_prefix=@symbol_prefix@
bindir=@bindir@
libdir=@libdir@
sharedlibdir=@sharedlibdir@
includedir=@includedir@

Name: @LIBNAME2@
Description: neozip compression library
Version: @VERSION@

Requires:
Libs: -L${libdir} -L${sharedlibdir} -l@UNIXLIBNAME@
Cflags: -I${includedir} @PKG_CONFIG_CFLAGS@
