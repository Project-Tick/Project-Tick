{% extends 'base.html.twig' %}

{% block title %}Log in - Project Tick{% endblock %}

{% block body %}
<section class="auth-section">
    <div class="container container-center reveal-up">
        <div class="card auth-card">
            <div class="auth-header">
                <img src="{{ asset('img/logo.svg') }}" alt="Project Tick Logo" class="auth-logo">
                <h1>Log in to Project Tick</h1>
                <p>Access your dashboard and developer resources.</p>
            </div>

            {% if error %}
                <div class="flash flash-error">
                    {{ error.messageKey|trans(error.messageData, 'security') }}
                </div>
            {% endif %}

            {% for message in app.flashes('error') %}
                <div class="flash flash-error">
                    {{ message }}
                </div>
            {% endfor %}

            <div class="auth-social-buttons stagger-reveal">
                <a href="{{ path('connect_keycloak_start') }}" class="btn btn-primary w-full">
                    <i class="fa-solid fa-key"></i> Sign in with Project Tick SSO
                </a>
            </div>

            <p class="auth-legal">
                By logging in, you agree to our <a href="#">terms</a> and <a href="#">privacy policy</a>.
            </p>
        </div>
    </div>
</section>
{% endblock %}

