{
    "type": "project",
    "license": "proprietary",
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require": {
        "php": ">=8.5.5",
        "ext-ctype": "*",
        "ext-iconv": "*",
        "doctrine/doctrine-bundle": "^3.2.2",
        "doctrine/doctrine-migrations-bundle": "^3.7.0",
        "doctrine/orm": "^3.6.3",
        "dompdf/dompdf": "0.8.6",
        "erusev/parsedown": "^1.8.0",
        "guzzlehttp/guzzle": "^7.10",
        "knplabs/github-api": "^3.16",
        "knpuniversity/oauth2-client-bundle": "^2.20.2",
        "league/oauth2-github": "^3.1.1",
        "phpdocumentor/reflection-docblock": "^5.6.7",
        "phpstan/phpdoc-parser": "^1.33.0",
        "symfony/asset": "6.4.34",
        "symfony/asset-mapper": "6.4.37",
        "symfony/console": "6.4.37",
        "symfony/doctrine-messenger": "6.4.34",
        "symfony/dotenv": "6.4.37",
        "symfony/expression-language": "8.0.8",
        "symfony/flex": "^2",
        "symfony/form": "6.4.36",
        "symfony/framework-bundle": "6.4.37",
        "symfony/http-client": "6.4.37",
        "symfony/intl": "6.4.36",
        "symfony/lock": "3.4.47",
        "symfony/mailer": "6.4.34",
        "symfony/mime": "6.4.37",
        "symfony/monolog-bundle": "^3.11.2",
        "symfony/notifier": "6.4.34",
        "symfony/process": "6.4.33",
        "symfony/property-access": "6.4.32",
        "symfony/property-info": "6.4.34",
        "symfony/rate-limiter": "5.4.47",
        "symfony/runtime": "6.4.30",
        "symfony/security-bundle": "6.4.36",
        "symfony/serializer": "6.4.37",
        "symfony/stimulus-bundle": "^2.35.0",
        "symfony/string": "6.4.34",
        "symfony/translation": "6.4.34",
        "symfony/twig-bundle": "6.4.32",
        "symfony/ux-turbo": "^3.0",
        "symfony/validator": "6.4.37",
        "symfony/web-link": "6.4.32",
        "symfony/yaml": "6.4.34",
        "twig/extra-bundle": "2.16.0",
        "twig/markdown-extra": "^3.24.0",
        "twig/twig": "2.16.1",
        "web-auth/cose-lib": "1.2.2",
        "web-auth/webauthn-lib": "1.2.2",
        "web-auth/webauthn-symfony-bundle": "1.2.2"
    },
    "config": {
        "allow-plugins": {
            "php-http/discovery": true,
            "symfony/flex": true,
            "symfony/runtime": true
        },
        "sort-packages": true
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "replace": {
        "symfony/polyfill-ctype": "*",
        "symfony/polyfill-iconv": "*",
        "symfony/polyfill-php72": "*",
        "symfony/polyfill-php73": "*",
        "symfony/polyfill-php74": "*",
        "symfony/polyfill-php80": "*",
        "symfony/polyfill-php81": "*"
    },
    "scripts": {
        "auto-scripts": {
            "cache:clear": "symfony-cmd",
            "assets:install %PUBLIC_DIR%": "symfony-cmd",
            "importmap:install": "symfony-cmd"
        },
        "post-install-cmd": [
            "@auto-scripts"
        ],
        "post-update-cmd": [
            "@auto-scripts"
        ]
    },
    "conflict": {
        "symfony/symfony": "*"
    },
    "extra": {
        "symfony": {
            "allow-contrib": false,
            "require": "6.4.*"
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6.34",
        "symfony/browser-kit": "6.4.32",
        "symfony/css-selector": "6.4.34",
        "symfony/debug-bundle": "6.4.35",
        "symfony/maker-bundle": "^1.67.0",
        "symfony/stopwatch": "6.4.24",
        "symfony/web-profiler-bundle": "6.4.36"
    }
}
